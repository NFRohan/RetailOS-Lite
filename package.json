{
  "name": "retailos-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "start": "next start",
    "lint": "eslint .",
    "worker": "tsx worker/src/index.ts",
    "worker:enqueue-demo": "tsx worker/src/scripts/enqueueDemo.ts",
    "worker:dry-run": "tsx worker/src/scripts/dryRunAnalyzeVisit.ts",
    "worker:dlq:replay": "tsx worker/src/scripts/replayDlq.ts",
    "rag:index-reports": "tsx worker/src/scripts/indexVisitReports.ts",
    "rag:clear-namespace": "tsx scripts/clear-pinecone-namespace.ts",
    "ops:archive": "tsx scripts/archive-operational-data.ts",
    "check:worker": "tsc --noEmit -p tsconfig.worker.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:extensions": "tsx scripts/setup-postgres-extensions.ts",
    "db:seed": "tsx prisma/seed.ts",
    "demo:build": "set COMPOSE_BAKE=false&& docker compose -f docker-compose.demo.yml build ai-service && docker compose -f docker-compose.demo.yml build web && docker compose -f docker-compose.demo.yml build worker && docker compose -f docker-compose.demo.yml build app-init",
    "demo:up": "docker compose -f docker-compose.demo.yml up",
    "demo:up:detached": "docker compose -f docker-compose.demo.yml up -d",
    "demo:down": "docker compose -f docker-compose.demo.yml down",
    "demo:logs": "docker compose -f docker-compose.demo.yml logs -f web worker ai-service",
    "test:whatsapp": "tsx scripts/test-whatsapp-alert.ts",
    "test:whatsapp:fraud": "tsx scripts/test-fraud-whatsapp-alert.ts",
    "test:outlet-resolution": "tsx scripts/test-outlet-resolution.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@sentry/nextjs": "^10.53.1",
    "@sentry/node": "^10.53.1",
    "@tanstack/react-query": "^5.62.8",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "framer-motion": "^11.15.0",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "next-auth": "^5.0.0-beta.25",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
