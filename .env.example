# AI service
AI_SERVICE_URL=http://127.0.0.1:8001
RETAILOS_AI_SERVICE_API_KEY=
AI_SERVICE_RATE_LIMIT_ENABLED=true
AI_SERVICE_RATE_LIMIT_PER_MINUTE=60
AI_SERVICE_RATE_LIMIT_FAIL_OPEN=false
AI_SERVICE_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379
RETAILOS_YOLO_MODEL_PATH=Detection Model/best.pt
RETAILOS_YOLO_BACKEND=local
RETAILOS_YOLO_IMAGE_SIZE=1280
RETAILOS_MODAL_YOLO_URL=
RETAILOS_YOLO_FALLBACK_LOCAL=true
RETAILOS_LLM_ENABLED=true
RETAILOS_LLM_MODEL=gpt-5.4-mini
RETAILOS_CHAT_MODEL=gpt-5.4-mini
RETAILOS_EMBEDDING_MODEL=text-embedding-3-small
RETAILOS_EMBEDDING_DIMENSIONS=512
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_HOST=
PINECONE_NAMESPACE=retailos-visit-reports

# Observability
APP_ENV=development
# Any non-local/development/test AI service environment requires RETAILOS_AI_SERVICE_API_KEY.
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=logs
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=retailos-lite-local
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=retailos-lite-local
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Image/object storage
# local keeps images in public/uploads. s3 targets MinIO, S3, R2, or any S3-compatible bucket.
IMAGE_STORAGE_DRIVER=local
IMAGE_STORAGE_LOCAL_DIR=public/uploads
IMAGE_STORAGE_LOCAL_PUBLIC_BASE=/uploads
IMAGE_STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:19000/retailos-images
IMAGE_STORAGE_INTERNAL_BASE_URL=http://127.0.0.1:19000/retailos-images
S3_ENDPOINT=http://127.0.0.1:19000
S3_PRESIGN_ENDPOINT=http://127.0.0.1:19000
S3_REGION=us-east-1
S3_BUCKET=retailos-images
S3_ACCESS_KEY_ID=retailos
S3_SECRET_ACCESS_KEY=retailos-secret
S3_FORCE_PATH_STYLE=true
S3_PREFIX=uploads

# Next.js + Auth
AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
DATABASE_URL=postgresql://retailos:retailos@127.0.0.1:5433/retailos
# In production, DATABASE_URL should point to PgBouncer/Prisma Accelerate.
# DATABASE_DIRECT_URL should point to the direct Postgres endpoint for Prisma schema operations.
DATABASE_DIRECT_URL=postgresql://retailos:retailos@127.0.0.1:5433/retailos
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_ALLOWED_EMAILS=
API_RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_FAIL_OPEN=false

# Worker
REDIS_URL=redis://127.0.0.1:6379
ANALYZE_VISIT_QUEUE=analyze_visit
ANALYZE_VISIT_DLQ=analyze_visit_dlq
EMBED_VISIT_REPORT_QUEUE=embed_visit_report
WORKER_CONCURRENCY=2
WORKER_METRICS_PORT=9101
WORKER_USE_LLM=true
WORKER_USE_PRISMA=true
FRAUD_GPS_THRESHOLD_METERS=200
FRAUD_TIMESTAMP_DELAY_HOURS=6
FRAUD_EXIF_GPS_THRESHOLD_METERS=300
FRAUD_EXIF_TIMESTAMP_DRIFT_HOURS=24

# Twilio WhatsApp (sandbox)
TWILIO_WHATSAPP_ENABLED=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
SUPERVISOR_WHATSAPP_TO=whatsapp:+8801303320518
APP_PUBLIC_URL=http://localhost:3000
